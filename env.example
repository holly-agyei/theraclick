# Copy to .env.local for local dev, or set these in your host (Vercel, Railway, etc.).
# Never commit real values. Never commit .env.local or serviceAccountKey.json.

# --- Firebase (client) — safe to expose in the browser bundle ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Public app URL (OAuth redirects, emails, absolute links) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Gemini AI (server only — keep secret) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Firebase Admin (server only — for /api/admin/* and Firestore from Node) ---
# Option A: JSON file on disk (default path: ./serviceAccountKey.json)
# SERVICE_ACCOUNT_KEY_PATH=/absolute/path/to/serviceAccountKey.json
#
# Option B: env vars (recommended on Vercel / PaaS). Private key: paste with \n for newlines.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the JSON "private_key" string only (BEGIN…END block). One line with \n is OK; real line breaks also work.
FIREBASE_ADMIN_PRIVATE_KEY=

# --- Admin API (protect admin HTTP routes) ---
ADMIN_API_KEY=

# --- One-time: bootstrap admin for /admin/login (node scripts/create-admin.js) ---
# ADMIN_SEED_USERNAME=
# ADMIN_SEED_PASSWORD=
# ADMIN_SEED_EMAIL=

# --- Optional: WebRTC TURN (voice/video). Omit if not using TURN. ---
# NEXT_PUBLIC_TURN_SERVER_URL=
# NEXT_PUBLIC_TURN_USERNAME=
# NEXT_PUBLIC_TURN_CREDENTIAL=

# --- Optional: email (if you add SMTP later) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# --- Optional: cron (session reminders) — send as Authorization: Bearer <secret> ---
# CRON_SECRET=
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}  # JSON string for /api/cron/session-reminders on Vercel
