rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Users — any authenticated user can READ profiles (needed for DM headers,
    // counselor listings, peer-mentor listings). Only the owner can WRITE.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;

      match /aiThreads/{threadId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
        match /messages/{messageId} {
          allow read, write: if isSignedIn() && request.auth.uid == userId;
        }
      }
    }

    // Direct messages — conversation metadata document
    match /directMessages/{chatId} {
      // Creating a new conversation: user must be in the participants they're writing
      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.participants;

      // Reading / updating an existing conversation: user must already be a participant
      allow read, update, delete: if isSignedIn() &&
        request.auth.uid in resource.data.participants;

      // Messages sub-collection
      match /messages/{messageId} {
        // READ: allow if the parent conversation doesn't exist yet (empty, nothing
        // to leak) OR user is a verified participant. This prevents the onSnapshot
        // listener from failing before the first message is ever sent.
        allow read: if isSignedIn() && (
          !exists(/databases/$(database)/documents/directMessages/$(chatId)) ||
          request.auth.uid in get(/databases/$(database)/documents/directMessages/$(chatId)).data.participants
        );

        // WRITE: parent must exist and user must be a participant
        allow write: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/directMessages/$(chatId)).data.participants;
      }
    }

    // Forums — all authenticated users can read/write
    match /forums/{forumId} {
      allow read, write: if isSignedIn();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();

        match /replies/{replyId} {
          allow read, write: if isSignedIn();
        }
      }
    }

    // Forum members — track who joined which forum
    match /forumMembers/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // Bookings
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.studentId ||
        request.auth.uid == resource.data.counselorId
      );
      allow create: if isSignedIn() && (
        request.auth.uid == request.resource.data.studentId ||
        request.auth.uid == request.resource.data.counselorId
      );
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.studentId ||
        request.auth.uid == resource.data.counselorId
      );
    }

    // Counselor availability — readable by all (students browse slots),
    // writable by all authenticated (counselor sets slots, student marks booked)
    match /counselorAvailability/{counselorId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Calls — WebRTC signaling
    match /calls/{callId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.callerId ||
        request.auth.uid == resource.data.receiverId
      );
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.callerId;
      allow update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.callerId ||
        request.auth.uid == resource.data.receiverId
      );

      match /signals/{signalId} {
        allow read, write: if isSignedIn() && (
          request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.callerId ||
          request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.receiverId
        );
      }
    }
  }
}
